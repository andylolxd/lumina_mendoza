NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Clave publicable (dashboard nuevo) — preferida
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# O clave anon JWT (legacy), si no usás publishable
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo servidor: carritos compartidos (/api/carts), panel Equipo (crear admins / contraseñas). Nunca en el cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Opcional: conexión Postgres (npm run migrate). Solo en .env.local — no commitear.
# Supabase → Project Settings → Database → Connection string → URI.
# Si la contraseña tiene ? # @ etc., codificá la parte contraseña: encodeURIComponent("tu_pass") en Node.
# DATABASE_URL=postgresql://postgres:PASSWORD_CODIFICADO@db.xxxxx.supabase.co:5432/postgres

NEXT_PUBLIC_WHATSAPP_E164=5492615000000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dominio sintético para login solo con usuario (usuario → usuario@{dominio})
# NEXT_PUBLIC_AUTH_LOGIN_DOMAIN=lumina.local
